@page
@model UrbanPlantRescueApp.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center py-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm p-4" style="border-radius: 16px !important;">
            <div class="text-center mb-4">
                <div style="font-size: 3rem;">🌿</div>
                <h2 class="fw-bold" style="color: #1b4332;">Добре дошъл!</h2>
                <p class="text-muted">Влез в своя акаунт</p>
            </div>

            <form id="loginForm" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Имейл адрес</label>
                    <input name="Input.Email" type="email" class="form-control form-control-lg"
                           placeholder="вашият@имейл.com" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Парола</label>
                    <input name="Input.Password" type="password" class="form-control form-control-lg"
                           placeholder="Вашата парола" />
                </div>

                <div class="mb-4 form-check">
                    <input name="Input.RememberMe" type="checkbox" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label text-muted" for="rememberMe">Запомни ме</label>
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill fw-bold py-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Влез
                </button>
            </form>

            <hr class="my-4" />

            <div class="text-center">
                <p class="text-muted mb-0">
                    Нямаш акаунт?
                    <a href="/Identity/Account/Register" class="fw-bold" style="color: #2d6a4f;">Регистрирай се</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}