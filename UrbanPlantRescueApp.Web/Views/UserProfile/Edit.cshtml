@model UrbanPlantRescueApp.Services.ViewModels.UserProfileFormViewModel

@{
    ViewData["Title"] = "Редактирай профил";
}

<div class="row justify-content-center py-4">
    <div class="col-md-7">
        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none d-inline-flex align-items-center gap-2"
                   style="color: #2d6a4f; font-weight: 500;">
                <i class="bi bi-arrow-left"></i> Обратно към профила
            </a>
        </div>

        <div class="card border-0 shadow p-5" style="border-radius: 24px !important;">
            <div class="text-center mb-5">
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                     style="width: 80px; height: 80px; background: linear-gradient(135deg, #d8f3dc, #b7e4c7); font-size: 2.5rem;">
                    👤
                </div>
                <h2 class="fw-bold mb-1" style="color: #1b4332;">Редактирай профила</h2>
                <p class="text-muted">Обнови информацията за твоя профил</p>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="FirstName" class="form-label d-flex align-items-center gap-2 mb-2">
                        <span class="d-flex align-items-center justify-content-center rounded-circle"
                              style="width: 28px; height: 28px; background-color: #d8f3dc; font-size: 0.85rem;">👤</span>
                        <span class="fw-bold" style="color: #1b4332;">Име <span class="text-muted fw-normal small">(незадължително)</span></span>
                    </label>
                    <input asp-for="FirstName" class="form-control form-control-lg"
                           style="border-radius: 12px; border: 2px solid #d8ede5; background-color: #fafffe;"
                           placeholder="Вашето име..." />
                    <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="LastName" class="form-label d-flex align-items-center gap-2 mb-2">
                        <span class="d-flex align-items-center justify-content-center rounded-circle"
                              style="width: 28px; height: 28px; background-color: #d8f3dc; font-size: 0.85rem;">👤</span>
                        <span class="fw-bold" style="color: #1b4332;">Фамилия <span class="text-muted fw-normal small">(незадължително)</span></span>
                    </label>
                    <input asp-for="LastName" class="form-control form-control-lg"
                           style="border-radius: 12px; border: 2px solid #d8ede5; background-color: #fafffe;"
                           placeholder="Вашата фамилия..." />
                    <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-5">
                    <label asp-for="Bio" class="form-label d-flex align-items-center gap-2 mb-2">
                        <span class="d-flex align-items-center justify-content-center rounded-circle"
                              style="width: 28px; height: 28px; background-color: #d8f3dc; font-size: 0.85rem;">📝</span>
                        <span class="fw-bold" style="color: #1b4332;">За мен <span class="text-muted fw-normal small">(незадължително)</span></span>
                    </label>
                    <textarea asp-for="Bio" class="form-control" rows="4"
                              style="border-radius: 12px; border: 2px solid #d8ede5; background-color: #fafffe;"
                              placeholder="Разкажи нещо за себе си..."></textarea>
                    <span asp-validation-for="Bio" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-lg fw-bold py-3"
                            style="background: linear-gradient(135deg, #2d6a4f, #40916c); color: white; border: none; border-radius: 14px; font-size: 1.1rem;">
                        <i class="bi bi-check-circle me-2"></i>Запази промените
                    </button>
                    <a asp-action="Index" class="btn btn-lg py-3"
                           style="border: 2px solid #d8ede5; border-radius: 14px; color: #6c757d; background: white;">
                        Отказ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}