@{
    ViewData["Title"] = "Начало";
}
<div class="hero-section rounded-4 mb-5 p-5" style="background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 50%, #40916c 100%); color: white;">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <span class="badge mb-3 px-3 py-2" style="background-color: #52b788; font-size: 0.85rem;">
                🌱 Платформа за спасяване на растения
            </span>
            <h1 class="display-3 fw-bold mb-4" style="line-height: 1.2;">
                Спаси градската <span style="color: #95d5b2;">природа</span>
            </h1>
            <p class="lead mb-5" style="color: #d8f3dc; font-size: 1.15rem;">
                Открий растения в нужда, помогни им да оцелеят и направи града по-зелен.
                Заедно можем да променим средата около нас.
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-controller="Plant" asp-action="Index"
                       class="btn btn-lg px-5 py-3 fw-bold rounded-pill"
                       style="background-color: #52b788; border: none; color: white;">
                    <i class="bi bi-flower2 me-2"></i>Разгледай растенията
                </a>
                <a asp-controller="Category" asp-action="Index"
                       class="btn btn-lg px-5 py-3 fw-bold rounded-pill"
                       style="background-color: transparent; border: 2px solid white; color: white;">
                    <i class="bi bi-grid me-2"></i>Виж категориите
                </a>
            </div>
        </div>
        <div class="col-lg-5 text-center d-none d-lg-block">
            <div style="font-size: 10rem; line-height: 1; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.3));">
                🌿
            </div>
        </div>
    </div>
</div>
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4" style="background: white; border-radius: 16px !important;">
            <div style="font-size: 3rem;">🌱</div>
            <h3 class="fw-bold mt-2" style="color: #2d6a4f;">Докладвай</h3>
            <p class="text-muted">Открий растение в нужда и го добави в системата за да получи помощ.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4" style="background: white; border-radius: 16px !important;">
            <div style="font-size: 3rem;">💚</div>
            <h3 class="fw-bold mt-2" style="color: #2d6a4f;">Спаси</h3>
            <p class="text-muted">Изпрати заявка за спасяване и помогни на растение да оцелее.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4" style="background: white; border-radius: 16px !important;">
            <div style="font-size: 3rem;">🏙️</div>
            <h3 class="fw-bold mt-2" style="color: #2d6a4f;">Озелени</h3>
            <p class="text-muted">Допринеси за по-зелен и здравословен град за всички нас.</p>
        </div>
    </div>
</div>
@if (!User.Identity!.IsAuthenticated)
{
    <div class="text-center py-5 rounded-4" style="background: white; border: 1px solid #d8ede5;">
        <h2 class="fw-bold mb-3" style="color: #1b4332;">Готов ли си да помогнеш? 🌿</h2>
        <p class="text-muted mb-4 fs-5">Регистрирай се безплатно и започни да спасяваш растения още днес.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-area="Identity" asp-page="/Account/Register"
                   class="btn btn-success btn-lg px-5 py-3 rounded-pill fw-bold">
                <i class="bi bi-person-plus me-2"></i>Регистрирай се
            </a>
            <a asp-area="Identity" asp-page="/Account/Login"
                   class="btn btn-outline-success btn-lg px-5 py-3 rounded-pill fw-bold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Вход
            </a>
        </div>
    </div>
}
else
{
    <div class="text-center py-5 rounded-4" style="background: white; border: 1px solid #d8ede5;">
        <h2 class="fw-bold mb-3" style="color: #1b4332;">Добре дошъл обратно! 🌿</h2>
        <p class="text-muted mb-4 fs-5">Провери новите растения в нужда и помогни на общността.</p>
        <a asp-controller="Plant" asp-action="Index"
               class="btn btn-success btn-lg px-5 py-3 rounded-pill fw-bold">
            <i class="bi bi-flower2 me-2"></i>Към каталога
        </a>
    </div>
}