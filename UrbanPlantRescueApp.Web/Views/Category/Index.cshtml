@model IEnumerable<UrbanPlantRescueApp.Services.ViewModels.CategoryViewModel>

@{
    ViewData["Title"] = "Категории";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="fw-bold mb-1">🌿 Категории</h1>
        <p class="text-muted mb-0">Видовете растения и тяхната класификация.</p>
    </div>
    @if (User.Identity!.IsAuthenticated)
    {
        <a asp-action="Create" class="btn btn-success btn-lg px-4 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Нова категория
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4 border">
        <div style="font-size: 4rem;">🌱</div>
        <h3 class="text-muted mt-3">Все още няма добавени категории.</h3>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var category in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a asp-action="Plants" asp-route-id="@category.Id" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm p-4" style="border-radius: 16px !important; background: white; transition: transform 0.2s ease, box-shadow 0.2s ease;">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 50px; height: 50px; background-color: #f0f7f4; font-size: 1.5rem;">
                                🌿
                            </div>
                        </div>
                        <h4 class="fw-bold mb-2" style="color: #1b4332;">@category.Name</h4>
                        <p class="text-muted small mb-3">
                            Всички растения класифицирани като <strong>@category.Name</strong>
                        </p>
                        <span class="text-success small fw-bold">
                            <i class="bi bi-arrow-right me-1"></i>Виж растенията
                        </span>
                    </div>
                </a>
            </div>
        }
    </div>
}

@section Scripts {
    <style>
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 2rem rgba(45, 106, 79, 0.1) !important;
        }
    </style>
}