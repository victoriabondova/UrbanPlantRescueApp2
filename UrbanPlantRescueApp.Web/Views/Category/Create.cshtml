@model UrbanPlantRescueApp.Services.ViewModels.CategoryFormViewModel

@{
    ViewData["Title"] = "Нова категория";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none" style="color: #2d6a4f;">
                <i class="bi bi-arrow-left me-1"></i>Обратно към категориите
            </a>
        </div>

        <div class="card border-0 shadow-sm p-4" style="border-radius: 16px !important;">
            <div class="text-center mb-4">
                <div style="font-size: 3rem;">🌿</div>
                <h2 class="fw-bold" style="color: #1b4332;">Нова категория</h2>
                <p class="text-muted">Създайте нова група за класификация на растенията</p>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-bold">Име на категорията</label>
                    <input asp-for="Name" class="form-control form-control-lg"
                           placeholder="напр. Стайни растения, Сукуленти..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="alert rounded-3 small" style="background-color: #f0f7f4; border: none; color: #2d6a4f;">
                    <i class="bi bi-info-circle me-2"></i>
                    Уверете се, че името е уникално и ясно описва групата.
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold py-3">
                        <i class="bi bi-plus-circle me-2"></i>Запази категорията
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill py-2">
                        Отказ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}