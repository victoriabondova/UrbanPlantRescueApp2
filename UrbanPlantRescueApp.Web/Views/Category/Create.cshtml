@model UrbanPlantRescueApp.Services.ViewModels.CategoryFormViewModel

@{
    ViewData["Title"] = "Нова Категория";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none text-success small fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> Обратно към списъка
                </a>
                <h2 class="fw-bold mt-2">Добавяне на категория</h2>
                <p class="text-muted">Създайте нова група за класификация на растенията.</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Име на категорията</label>
                            <div class="input-group has-validation">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-tag-fill text-success"></i>
                                </span>
                                <input asp-for="Name" 
                                       class="form-control border-start-0 ps-0 shadow-none focus-success" 
                                       placeholder="напр. Стайни растения, Сукуленти..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="alert alert-light border-0 small text-muted rounded-3 mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Уверете се, че името е уникално и ясно описва групата.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-check-lg me-2"></i>Запази категорията
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
                                Отказ
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            @section Scripts {
                @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
                <style>
                    .focus-success:focus {
                        border-color: #198754;
                        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
                    }
                    .input-group-text {
                        border-radius: 0.5rem 0 0 0.5rem;
                    }
                    .form-control {
                        border-radius: 0 0.5rem 0.5rem 0;
                    }
                </style>
            }
        </div>
    </div>
</div>