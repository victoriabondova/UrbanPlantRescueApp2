@model UrbanPlantRescueApp.Services.ViewModels.PlantListViewModel

@{
    ViewData["Title"] = "Каталог Растения";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3">
    <div>
        <h1 class="fw-bold mb-1">🌿 Каталог с растения</h1>
        <p class="text-muted mb-0">Открийте растения в нужда и помогнете за тяхното спасяване.</p>
    </div>
    @if (User.Identity!.IsAuthenticated)
    {
        <a asp-action="Create" class="btn btn-success btn-lg px-4 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Добави растение
        </a>
    }
</div>

@* Search Form *@
<form method="get" asp-action="Index" class="mb-5">
    <div class="input-group shadow-sm" style="border-radius: 50px; overflow: hidden;">
        <span class="input-group-text border-0 ps-4" style="background: white;">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text"
               name="searchTerm"
               value="@Model.SearchTerm"
               class="form-control border-0 py-3"
               style="background: white;"
               placeholder="Търси по име, описание или категория..." />
        <button type="submit" class="btn btn-success px-4 fw-bold">
            Търси
        </button>
        @if (!string.IsNullOrEmpty(Model.SearchTerm))
        {
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-x-lg"></i>
            </a>
        }
    </div>
</form>

<div class="row g-4">
    @if (!Model.Plants.Any())
    {
        <div class="col-12 text-center py-5 bg-white rounded-4 border">
            <div style="font-size: 4rem;">🌱</div>
            <h3 class="text-muted mt-3">Няма намерени растения.</h3>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-success mt-3 rounded-pill px-4">
                    Виж всички растения
                </a>
            }
        </div>
    }
    else
    {
        @foreach (var plant in Model.Plants)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 16px !important; background: white; transition: transform 0.2s ease;">
                    @if (!string.IsNullOrEmpty(plant.ImageUrl))
                    {
                        <img src="@plant.ImageUrl" class="card-img-top"
                             style="height: 200px; object-fit: cover; border-radius: 16px 16px 0 0 !important;" alt="@plant.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center"
                             style="height: 200px; background-color: #f0f7f4; border-radius: 16px 16px 0 0 !important;">
                            <span style="font-size: 5rem;">🌿</span>
                        </div>
                    }
                    <div class="card-body p-4 d-flex flex-column">
                        <span class="badge rounded-pill mb-2 px-3 py-2 align-self-start"
                              style="background-color: #f0f7f4; color: #2d6a4f; font-size: 0.8rem;">
                            @plant.CategoryName
                        </span>
                        <h5 class="card-title fw-bold mb-2" style="color: #1b4332;">@plant.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">
                            @(plant.Description.Length > 100 ? plant.Description.Substring(0, 100) + "..." : plant.Description)
                        </p>
                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Details" asp-route-id="@plant.Id"
                                   class="btn btn-success rounded-pill flex-grow-1">
                                <i class="bi bi-eye me-1"></i>Детайли
                            </a>
                            @if (User.Identity!.IsAuthenticated &&
                                                            (User.IsInRole("Admin") || User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == plant.AddedByUserId))
                            {
                                <a asp-action="Edit" asp-route-id="@plant.Id"
                                       class="btn btn-outline-warning rounded-pill px-3">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@plant.Id"
                                       class="btn btn-outline-danger rounded-pill px-3">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@* Pagination *@
@if (Model.TotalPages > 1)
{
    <nav class="mt-5">
        <ul class="pagination justify-content-center gap-2">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link rounded-pill px-4"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           style="color: #2d6a4f; border-color: #d8ede5;">
                        <i class="bi bi-arrow-left me-1"></i>Предишна
                    </a>
                </li>
            }
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item">
                    <a class="page-link rounded-pill px-4"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchTerm="@Model.SearchTerm"
                           style="@(i == Model.CurrentPage ? "background-color: #2d6a4f; color: white; border-color: #2d6a4f;" : "color: #2d6a4f; border-color: #d8ede5;")">
                        @i
                    </a>
                </li>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link rounded-pill px-4"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           style="color: #2d6a4f; border-color: #d8ede5;">
                        Следваща<i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <style>
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 2rem rgba(45, 106, 79, 0.1) !important;
        }
    </style>
}