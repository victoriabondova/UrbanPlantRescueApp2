@model UrbanPlantRescueApp.Services.ViewModels.PlantListViewModel

@{
    ViewData["Title"] = "Каталог Растения";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3">
        <div>
            <h1 class="fw-bold mb-1">🌿 Каталог с растения</h1>
            <p class="text-muted mb-0">Открийте растения в нужда и помогнете за тяхното спасяване.</p>
        </div>
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-action="Create" class="btn btn-success btn-lg shadow-sm px-4">
                <i class="bi bi-plus-circle me-2"></i>Добави растение
            </a>
        }
    </div>

    {{!-- Search Form --}}
    <form method="get" asp-action="Index" class="mb-5">
        <div class="input-group shadow-sm">
            <input type="text"
                   name="searchTerm"
                   value="@Model.SearchTerm"
                   class="form-control form-control-lg border-0 rounded-start-pill"
                   placeholder="Търси по име, описание или категория..." />
            <button type="submit" class="btn btn-success px-4 rounded-end-pill">
                <i class="bi bi-search me-1"></i> Търси
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill ms-2">
                    Изчисти
                </a>
            }
        </div>
    </form>

    <div class="row g-4">
        @if (!Model.Plants.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="display-1 text-muted"><i class="bi bi-flower1"></i></div>
                <h3 class="text-muted mt-3">Няма намерени растения.</h3>
            </div>
        }
        else
        {
            @foreach (var plant in Model.Plants)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm hover-card">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@plant.Name</h5>
                            <p class="card-text text-muted flex-grow-1 text-truncate-3">
                                @plant.Description
                            </p>
                            <hr class="text-muted opacity-25">
                            <div class="d-flex justify-content-between align-items-center mt-auto gap-2">
                                <a asp-action="Details" asp-route-id="@plant.Id" class="btn btn-outline-success px-3 rounded-pill">
                                    Детайли
                                </a>
                                @if (User.Identity.IsAuthenticated &&
                                    (User.IsInRole("Admin") || User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == plant.AddedByUserId))
                                {
                                    <a asp-action="Edit" asp-route-id="@plant.Id" class="btn btn-outline-warning px-3 rounded-pill">
                                        Редактирай
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@plant.Id" class="btn btn-outline-danger px-3 rounded-pill">
                                        Изтрий
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    {{!-- Pagination --}}
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link rounded-pill me-1"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-searchTerm="@Model.SearchTerm">
                            ← Предишна
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link rounded-pill me-1"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchTerm="@Model.SearchTerm">
                            @i
                        </a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link rounded-pill"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-searchTerm="@Model.SearchTerm">
                            Следваща →
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <style>
        .hover-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .hover-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
        }
        .text-truncate-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}