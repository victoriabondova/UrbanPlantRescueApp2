@model UrbanPlantRescueApp.Services.ViewModels.PlantFormViewModel

@{
    ViewData["Title"] = "Добави ново растение";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="card-title mb-0">Добавяне на растение</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @* Валидация за целия модел *@
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Име на растението</label>
                            <input asp-for="Name" class="form-control" placeholder="напр. Фикус" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label">Линк към снимка</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="Постави линк към изображение..." />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Категория</label>
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">-- Избери категория --</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Запази растението</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}