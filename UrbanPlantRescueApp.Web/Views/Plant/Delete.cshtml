@model UrbanPlantRescueApp.Services.ViewModels.PlantViewModel

@{
    ViewData["Title"] = "Изтриване на растение";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="text-center mb-4">
                <div class="display-1 text-danger mb-3">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
                <h2 class="fw-bold">Потвърдете изтриването</h2>
                <p class="text-muted">Сигурни ли сте, че искате да премахнете този запис? Това действие не може да бъде отменено.</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
                <div class="row g-0 align-items-center">
                    <div class="col-4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-fluid h-100 object-fit-cover" style="min-height: 150px;" alt="@Model.Name">
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center h-100" style="min-height: 150px;">
                                <i class="bi bi-tree text-muted fs-1"></i>
                            </div>
                        }
                    </div>
                    <div class="col-8">
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-1">@Model.Name</h5>
                            <p class="badge bg-secondary mb-2">@Model.CategoryName</p>
                            <p class="card-text text-muted small text-truncate-2">
                                @Model.Description
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-danger bg-danger bg-opacity-10 rounded-4 p-4">
                <form asp-action="Delete" method="post" class="d-flex gap-3">
                    <input type="hidden" asp-for="Id" />
                    
                    <button type="submit" class="btn btn-danger btn-lg flex-grow-1 rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-trash3-fill me-2"></i>Да, изтрий го
                    </button>
                    
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg flex-grow-1 rounded-pill fw-bold bg-white">
                        Отказ
                    </a>
                </form>
            </div>
            
            <div class="text-center mt-4">
                <a asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-muted small">
                    <i class="bi bi-info-circle me-1"></i> Преглед на пълните детайли
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .object-fit-cover { object-fit: cover; }
        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}