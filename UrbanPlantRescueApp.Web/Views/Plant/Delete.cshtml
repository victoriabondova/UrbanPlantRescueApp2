@model UrbanPlantRescueApp.Services.ViewModels.PlantViewModel

@{
    ViewData["Title"] = "Изтрий растение";
}

<div class="row justify-content-center py-4">
    <div class="col-md-6">
        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none d-inline-flex align-items-center gap-2"
                   style="color: #2d6a4f; font-weight: 500;">
                <i class="bi bi-arrow-left"></i> Обратно към каталога
            </a>
        </div>

        <div class="card border-0 shadow p-5 text-center" style="border-radius: 24px !important;">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                 style="width: 80px; height: 80px; background: linear-gradient(135deg, #ffe0e0, #ffb3b3); font-size: 2.5rem;">
                🗑️
            </div>
            <h2 class="fw-bold mb-1" style="color: #1b4332;">Изтриване на растение</h2>
            <p class="text-muted mb-4">Сигурен ли си че искаш да изтриеш това растение?</p>

            <div class="p-4 mb-4 text-start" style="background-color: #f0f7f4; border-radius: 16px;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="rounded-3 mb-3 w-100"
                         style="height: 200px; object-fit: cover;" alt="@Model.Name" />
                }
                else
                {
                    <div class="rounded-3 mb-3 d-flex align-items-center justify-content-center"
                         style="height: 150px; background-color: #d8ede5;">
                        <span style="font-size: 4rem;">🌿</span>
                    </div>
                }
                <h4 class="fw-bold mb-2" style="color: #1b4332;">@Model.Name</h4>
                <span class="badge rounded-pill px-3 py-2 mb-2"
                      style="background-color: #d8ede5; color: #2d6a4f;">
                    🌿 @Model.CategoryName
                </span>
                <p class="text-muted small mb-0 mt-2">@Model.Description</p>
            </div>

            <div class="p-3 mb-4 text-start rounded-3"
                 style="background-color: #fff8e1; border-left: 4px solid #f0a500;">
                <i class="bi bi-exclamation-triangle me-2" style="color: #f0a500;"></i>
                <strong>Внимание!</strong> Това действие е необратимо. Всички заявки за спасяване към това растение също ще бъдат изтрити.
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-lg fw-bold py-3"
                            style="background: linear-gradient(135deg, #c0392b, #e74c3c); color: white; border: none; border-radius: 14px; font-size: 1.1rem;">
                        <i class="bi bi-trash me-2"></i>Да, изтрий растението
                    </button>
                    <a asp-action="Index" class="btn btn-lg py-3"
                           style="border: 2px solid #d8ede5; border-radius: 14px; color: #6c757d; background: white;">
                        Отказ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>